# Music Scan — LOCAL DEVELOPMENT ONLY
# Copy to .env.local (gitignored). Never commit real keys.
#
# Direct OpenAI access for testing on your machine:
VITE_OPENAI_API_KEY=sk-your-key-here
VITE_MUSIC_SCAN_MODEL=gpt-4o

# Production builds should use a backend instead (see README):
# VITE_MUSIC_SCAN_API_URL=https://your-backend.example.com/scan-music
